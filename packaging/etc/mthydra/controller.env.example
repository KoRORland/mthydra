# /etc/mthydra/controller.env
# Environment variables for the mthydra-controller systemd service.
# Copy to /etc/mthydra/controller.env and fill in real values.
# Mode: 0600 root:root — this file contains secrets.

# Operating mode (default: production).
# Set to "dryrun" on throwaway VMs during the monthly backup-restore dry-run (spec A §12).
# Set to "offline" for forensic-only inspection of a restored DB.
# MTHYDRA_MODE=production

# Required in dryrun mode — S3 bucket to use instead of the prod bucket.
# MTHYDRA_BUCKET_OVERRIDE=mthydra-controller-state-dryrun

# AWS region for S3/B2 endpoint calls (default: us-east-1).
# MTHYDRA_BACKUP_REGION=us-east-1

# SMTP settings for gap-alarm emails (consumed by mthydra-backup-monitor
# and the controller's self-alarm path once spec J ships).
# All of these are required on the monitor host; optional on the controller itself.
# MTHYDRA_SMTP_HOST=smtp.example.com
# MTHYDRA_SMTP_PORT=465
# MTHYDRA_SMTP_USER=alerter@example.com
# MTHYDRA_SMTP_PASS=app-password-here
# MTHYDRA_SMTP_FROM=alerter@example.com
