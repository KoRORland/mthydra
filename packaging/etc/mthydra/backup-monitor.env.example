# /etc/mthydra/backup-monitor.env
# Environment variables for the mthydra-backup-monitor systemd service.
# Copy to /etc/mthydra/backup-monitor.env and fill in real values.
# Mode: 0600 root:root — this file contains secrets.

# B2 (or S3-compatible) secret access key for the read-only monitor credential.
# This must be a SEPARATE key from the controller's write credential, scoped
# read-only to index.json on the backup bucket (spec A §8).
MTHYDRA_B2_SECRET=your-b2-read-only-secret-key-here

# AWS region for the B2/S3 endpoint (default: us-east-1).
# MTHYDRA_BACKUP_REGION=us-east-1

# SMTP settings for gap-alarm emails.
MTHYDRA_SMTP_HOST=smtp.example.com
MTHYDRA_SMTP_PORT=465
MTHYDRA_SMTP_USER=alerter@example.com
MTHYDRA_SMTP_PASS=app-password-here
# MTHYDRA_SMTP_FROM=alerter@example.com  # defaults to MTHYDRA_SMTP_USER if unset
